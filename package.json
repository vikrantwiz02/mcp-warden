{
  "name": "mcp-warden",
  "version": "1.0.0",
  "description": "Policy enforcement and guardrails for MCP-compatible tool execution.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-warden": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vikrantwiz02/mcp-warden.git"
  },
  "bugs": {
    "url": "https://github.com/vikrantwiz02/mcp-warden/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "guardian",
    "policy",
    "security",
    "rate-limit",
    "circuit-breaker",
    "pii-redaction"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "commander": "^14.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
